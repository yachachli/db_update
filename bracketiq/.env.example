# Copy to .env and fill in your values. Do not commit .env.
# For GitHub Actions, set these as repository Secrets (except CACHE_DIR/HISTORICAL_DIR if using defaults).

KENPOM_EMAIL=your_kenpom_email
KENPOM_PASSWORD=your_kenpom_password
ODDS_API_KEY=your_odds_api_key
NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

CACHE_DIR=app/data/cache
HISTORICAL_DIR=app/data/historical
CURRENT_SEASON=2026
