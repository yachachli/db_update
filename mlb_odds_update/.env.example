# Required
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
ODDS_API_KEY=your_the_odds_api_v4_key

# Optional
LOG_LEVEL=INFO

# Operation modes:
#
# 1) Single date (interpreted as a US/Eastern slate date):
# TARGET_DATE=2026-07-07
#
# 2) Default (no env set): today (US/Eastern)
