# SportMonks (required for fixture fetch + prediction bootstrap)
SPORTMONKS_API_KEY=your_api_key_here
SPORTMONKS_BASE_URL=https://api.sportmonks.com/v3/football

# Neon Postgres — use any of these names (db_update CI uses DB_URL → NEON_DATABASE_URL)
NEON_DATABASE_URL=postgresql://user:password@ep-xxxxx.aws.neon.tech/dbname?sslmode=require
# DB_URL=postgresql://...
# DATABASE_URL=postgresql://...
