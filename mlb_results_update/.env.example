# Required
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Optional
LOG_LEVEL=INFO

# Operation modes (mutually exclusive — first match wins):
#
# 1) Manual date range:
# BACKFILL_START=20260501
# BACKFILL_END=20260515
#
# 2) Auto rolling (re-runs yesterday + last N days):
# BACKFILL_DAYS=7
#
# 3) Single date:
# TARGET_DATE=2026-05-14
#
# 4) Default (no env set): yesterday (UTC date - 1)
